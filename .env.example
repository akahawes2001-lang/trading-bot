# Режим работы бота: demo для демо-торговли или live для реальной торговли.
BOT_MODE=demo

# Начальный виртуальный баланс для демо-режима.
DEMO_BALANCE=10000

# Процент риска на сделку; может переопределяться параметром NUMBER_OF_POSITIONS.
RISK_PERCENT=2

# Максимальное количество одновременных позиций; может переопределяться параметром NUMBER_OF_POSITIONS.
MAX_POSITIONS=3

# API-ключ Bybit. Для демо-режима можно оставить пустым, если не нужны приватные API-методы.
BYBIT_API_KEY=

# Секретный ключ Bybit. Для демо-режима можно оставить пустым, если не нужны приватные API-методы.
BYBIT_SECRET_KEY=

# Использовать тестовую сеть Bybit: true или false.
BYBIT_TESTNET=true

# Количество свечей для подтверждения пробития уровня.
BREAKOUT_CONFIRMATION_CANDLES=3

# Период для поиска уровней поддержки и сопротивления.
SUPPORT_RESISTANCE_PERIOD=20

# Минимальный объём для фильтрации торговых сигналов.
MIN_VOLUME_THRESHOLD=1000000

# Количество позиций для распределения капитала; также переопределяет RISK_PERCENT и MAX_POSITIONS.
NUMBER_OF_POSITIONS=10

# Минимальный объём торгов для отбора символов.
MIN_VOLUME=1000000

# Количество топовых символов при динамическом выборе торговых пар.
TOP_SYMBOLS_COUNT=20

# Использовать динамический выбор символов: true или false. Если false, используется TRADING_SYMBOLS.
USE_DYNAMIC_SYMBOLS=true

# Отправлять реальные ордера в демо-режиме: true или false. Используйте с осторожностью.
DEMO_SEND_REAL_ORDERS=false

# Список торговых символов через запятую, если USE_DYNAMIC_SYMBOLS=false.
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,ADAUSDT,DOTUSDT

# Порт веб-сервера. На Render задаётся автоматически, локально по умолчанию используется 3000.
PORT=3000

# Окружение Node.js: development или production.
NODE_ENV=development

# Токен Telegram-бота для уведомлений. Оставьте пустым, чтобы не использовать Telegram.
TELEGRAM_BOT_TOKEN=

# ID Telegram-чата для отправки уведомлений. Оставьте пустым, чтобы не использовать Telegram.
TELEGRAM_CHAT_ID=